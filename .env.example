# ============================================
# Photo Portfolio - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!

# --- Site Branding ---
# Your site/brand name shown in the header and meta tags
VITE_SITE_NAME=My Photography
# Your deployed site URL (used for Open Graph / SEO meta tags)
VITE_SITE_URL=https://www.example.com

# --- AWS S3 Configuration ---
# Create an S3 bucket and IAM user with PutObject/GetObject/DeleteObject permissions
# See SETUP.md for detailed instructions
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name

# --- CloudFront CDN (Optional) ---
# If you set up a CloudFront distribution in front of your S3 bucket,
# enter the domain here for faster image delivery. Leave blank to serve directly from S3.
VITE_CLOUDFRONT_DOMAIN=

# --- Supabase Configuration ---
# Create a free project at https://supabase.com
# Find these values in: Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service key (server-only, NEVER expose to the browser)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Google Analytics (Optional) ---
# Get your Measurement ID from https://analytics.google.com
VITE_GOOGLE_ANALYTICS_ID=

# --- Printful API (Optional) ---
# Only needed if you want to sell prints via Printful
VITE_PRINTFUL_API_KEY=